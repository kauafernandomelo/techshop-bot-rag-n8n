          "id": "omaHPjuIpBTnwKHY",
          "name": "Google Gemini(PaLM) Api account"
        }
      }
    },
    {
      "id": "a1b2c3d4-0001-4a00-8000-000000000004",
      "name": "Memória da conversa",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
